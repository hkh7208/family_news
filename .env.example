# 공통
DJANGO_SECRET_KEY=replace_with_strong_secret_key
DB_TARGET=local
DB_CONN_MAX_AGE=60

# 로컬 PC MariaDB
LOCAL_DB_NAME=family_news
LOCAL_DB_USER=family_news
LOCAL_DB_PASSWORD=your_local_password
LOCAL_DB_HOST=127.0.0.1
LOCAL_DB_PORT=3306

# Synology NAS MariaDB
NAS_DB_NAME=family_news
NAS_DB_USER=family_news
NAS_DB_PASSWORD=your_nas_password
NAS_DB_HOST=192.168.0.200
NAS_DB_PORT=3307

# 운영(prod.py) 허용 호스트 (쉼표 구분)
DJANGO_ALLOWED_HOSTS=192.168.0.107,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://192.168.0.107:8090

# 이메일 발송 설정
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email@example.com
EMAIL_HOST_PASSWORD=your_email_app_password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=family-news <your_email@example.com>

# 가입 신청 알림 수신 주소
SIGNUP_REQUEST_NOTIFY_EMAIL=hkh7208@poscodx.com

# 메일 본문에 들어갈 사이트 절대 주소
SITE_BASE_URL=http://127.0.0.1:8000
