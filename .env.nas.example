# Synology NAS 배포용 (.env)
# 경로: /volume1/web/family_news/app/.env

# Django
DJANGO_SECRET_KEY=replace_with_strong_secret_key
DJANGO_ALLOWED_HOSTS=jakesto.synology.me,jakesto.snology.me,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://jakesto.synology.me:8090,http://jakesto.snology.me:8090

# DB 타깃
DB_TARGET=nas
DB_CONN_MAX_AGE=60

# NAS MariaDB
NAS_DB_NAME=family_news
NAS_DB_USER=family_news
NAS_DB_PASSWORD=replace_with_nas_db_password
NAS_DB_HOST=192.168.0.250
NAS_DB_PORT=3306

# 이메일 발송 설정
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email@example.com
EMAIL_HOST_PASSWORD=your_email_app_password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=family-news <your_email@example.com>

# 가입 신청 알림 수신 주소
SIGNUP_REQUEST_NOTIFY_EMAIL=hkh7208@poscodx.com

# 메일 본문에 들어갈 사이트 절대 주소
SITE_BASE_URL=http://jakesto.synology.me:8090
